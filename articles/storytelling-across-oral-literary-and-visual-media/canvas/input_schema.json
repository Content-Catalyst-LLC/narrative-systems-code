    "temporal_control": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_relation": {"type": "number", "minimum": 0, "maximum": 1},
    "contextual_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "voice_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_shift": {"type": "number", "minimum": 0, "maximum": 1},
