{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storytelling Value Governance Canvas Input",
  "type": "object",
  "required": [
    "item",
    "story_context",
    "clarity",
    "evidence_grounding",
    "narrative_responsibility",
    "ethical_stakes"
  ],
  "properties": {
    "item": {"type": "string"},
    "story_context": {"type": "string"},
    "clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_grounding": {"type": "number", "minimum": 0, "maximum": 1},
    "memory_continuity": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_reasoning": {"type": "number", "minimum": 0, "maximum": 1},
    "dignity_protection": {"type": "number", "minimum": 0, "maximum": 1},
    "public_usefulness": {"type": "number", "minimum": 0, "maximum": 1},
    "truthfulness": {"type": "number", "minimum": 0, "maximum": 1},
    "context_adequacy": {"type": "number", "minimum": 0, "maximum": 1},
    "consent_discipline": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_disclosure": {"type": "number", "minimum": 0, "maximum": 1},
    "revision_openness": {"type": "number", "minimum": 0, "maximum": 1},
    "accountability": {"type": "number", "minimum": 0, "maximum": 1},
    "oversimplification": {"type": "number", "minimum": 0, "maximum": 1},
    "emotional_exploitation": {"type": "number", "minimum": 0, "maximum": 1},
    "scapegoating": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "platform_frictionlessness": {"type": "number", "minimum": 0, "maximum": 1},
    "human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "source_traceability": {"type": "number", "minimum": 0, "maximum": 1},
    "ai_human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "ai_consent_discipline": {"type": "number", "minimum": 0, "maximum": 1},
    "use_limit_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "correction_process": {"type": "number", "minimum": 0, "maximum": 1},
    "cultural_context": {"type": "number", "minimum": 0, "maximum": 1},
    "ethical_stakes": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
