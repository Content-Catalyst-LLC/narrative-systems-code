{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legal Narrative Responsibility Canvas Input",
  "type": "object",
  "required": [
    "item",
    "claim_context",
    "relevance",
    "authentication",
    "provenance",
    "public_consequence"
  ],
  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "relevance": {"type": "number", "minimum": 0, "maximum": 1},
    "authentication": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance": {"type": "number", "minimum": 0, "maximum": 1},
    "corroboration": {"type": "number", "minimum": 0, "maximum": 1},
    "cross_checking": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_notation": {"type": "number", "minimum": 0, "maximum": 1},
    "overcoherence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidentiary_gap": {"type": "number", "minimum": 0, "maximum": 1},
    "stereotype_reliance": {"type": "number", "minimum": 0, "maximum": 1},
    "causation_flattening": {"type": "number", "minimum": 0, "maximum": 1},
    "affective_bias": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "opportunity_to_be_heard": {"type": "number", "minimum": 0, "maximum": 1},
    "discovery_access": {"type": "number", "minimum": 0, "maximum": 1},
    "testimony_context": {"type": "number", "minimum": 0, "maximum": 1},
    "record_access": {"type": "number", "minimum": 0, "maximum": 1},
    "correction_pathway": {"type": "number", "minimum": 0, "maximum": 1},
    "procedural_posture_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "witness_dignity": {"type": "number", "minimum": 0, "maximum": 1},
    "testimony_care": {"type": "number", "minimum": 0, "maximum": 1},
    "role_complexity": {"type": "number", "minimum": 0, "maximum": 1},
    "remedy_connection": {"type": "number", "minimum": 0, "maximum": 1},
    "hallucinated_authority": {"type": "number", "minimum": 0, "maximum": 1},
    "summary_dependence": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "procedural_distortion": {"type": "number", "minimum": 0, "maximum": 1},
    "bias_reproduction": {"type": "number", "minimum": 0, "maximum": 1},
    "human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
