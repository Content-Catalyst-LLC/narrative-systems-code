    "local_context": {"type": "number", "minimum": 0, "maximum": 1},
    "source_context": {"type": "number", "minimum": 0, "maximum": 1},
    "alternative_lens": {"type": "number", "minimum": 0, "maximum": 1},
    "gender_complexity": {"type": "number", "minimum": 0, "maximum": 1},
