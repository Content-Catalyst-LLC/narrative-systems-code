    "relational_motion": {"type": "number", "minimum": 0, "maximum": 1},
    "cyclical_form": {"type": "number", "minimum": 0, "maximum": 1},
    "witness_structure": {"type": "number", "minimum": 0, "maximum": 1},
    "care_labor": {"type": "number", "minimum": 0, "maximum": 1},
    "fragmented_form": {"type": "number", "minimum": 0, "maximum": 1},
    "open_process": {"type": "number", "minimum": 0, "maximum": 1},
