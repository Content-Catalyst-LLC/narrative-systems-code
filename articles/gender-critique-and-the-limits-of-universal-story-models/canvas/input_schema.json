    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"},
    "stage_evidence": {"type": "number", "minimum": 0, "maximum": 1},
    "agency_match": {"type": "number", "minimum": 0, "maximum": 1},
    "transformation_correspondence": {"type": "number", "minimum": 0, "maximum": 1},
    "contextual_harmony": {"type": "number", "minimum": 0, "maximum": 1},
    "resolution_similarity": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "archive_bias": {"type": "number", "minimum": 0, "maximum": 1},
    "gender_binary_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "cultural_flattening": {"type": "number", "minimum": 0, "maximum": 1},
    "intersectional_erasure": {"type": "number", "minimum": 0, "maximum": 1},
