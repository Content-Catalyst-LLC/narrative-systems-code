    "claim_context": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"},
    "consequential_action": {"type": "number", "minimum": 0, "maximum": 1},
    "limit_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "reversal": {"type": "number", "minimum": 0, "maximum": 1},
    "recognition_knowledge": {"type": "number", "minimum": 0, "maximum": 1},
    "irreversibility": {"type": "number", "minimum": 0, "maximum": 1},
    "witness_burden": {"type": "number", "minimum": 0, "maximum": 1},
    "repeated_pattern": {"type": "number", "minimum": 0, "maximum": 1},
    "seasonal_ritual_signal": {"type": "number", "minimum": 0, "maximum": 1},
    "generational_transmission": {"type": "number", "minimum": 0, "maximum": 1},
