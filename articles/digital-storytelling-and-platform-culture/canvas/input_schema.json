    "visibility_provenance_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_care": {"type": "number", "minimum": 0, "maximum": 1},
    "medium_format_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "ethical_governance": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_spread": {"type": "number", "minimum": 0, "maximum": 1},
    "compression_severity": {"type": "number", "minimum": 0, "maximum": 1},
    "hostile_context_exposure": {"type": "number", "minimum": 0, "maximum": 1},
