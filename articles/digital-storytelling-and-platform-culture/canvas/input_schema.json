    "sensitive_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_review": {"type": "number", "minimum": 0, "maximum": 1},
    "hook_overdependence": {"type": "number", "minimum": 0, "maximum": 1},
    "trend_compliance": {"type": "number", "minimum": 0, "maximum": 1},
