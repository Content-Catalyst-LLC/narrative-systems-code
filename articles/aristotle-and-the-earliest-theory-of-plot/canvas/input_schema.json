{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aristotelian Plot Canvas Input",
  "type": "object",
  "required": ["item", "story_type", "action_clarity", "causal_linkage", "episode_dependency", "turning_point_relevance"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "action_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "causal_linkage": {"type": "number", "minimum": 0, "maximum": 1},
    "episode_dependency": {"type": "number", "minimum": 0, "maximum": 1},
    "turning_point_relevance": {"type": "number", "minimum": 0, "maximum": 1},
    "resolution_support": {"type": "number", "minimum": 0, "maximum": 1},
    "goal_coherence": {"type": "number", "minimum": 0, "maximum": 1},
    "direction_change": {"type": "number", "minimum": 0, "maximum": 1},
    "knowledge_change": {"type": "number", "minimum": 0, "maximum": 1},
    "preparation_strength": {"type": "number", "minimum": 0, "maximum": 1},
    "consequence_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "emotional_intellectual_impact": {"type": "number", "minimum": 0, "maximum": 1},
    "character_action_integration": {"type": "number", "minimum": 0, "maximum": 1},
    "genre_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "medium_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "cultural_awareness": {"type": "number", "minimum": 0, "maximum": 1},
    "hero_template_saturation": {"type": "number", "minimum": 0, "maximum": 1},
    "closure_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "unity_bias": {"type": "number", "minimum": 0, "maximum": 1},
    "genre_bias": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
