{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compact Oral Forms Canvas Input",
  "type": "object",
  "required": ["item", "oral_form", "form_identification", "speaker_role", "occasion_notes"],
  "properties": {
    "item": {"type": "string"},
    "oral_form": {"type": "string"},
    "form_identification": {"type": "number", "minimum": 0, "maximum": 1},
    "speaker_role": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_documentation": {"type": "number", "minimum": 0, "maximum": 1},
    "occasion_notes": {"type": "number", "minimum": 0, "maximum": 1},
    "place_linkage": {"type": "number", "minimum": 0, "maximum": 1},
    "use_context": {"type": "number", "minimum": 0, "maximum": 1},
    "rhythm": {"type": "number", "minimum": 0, "maximum": 1},
    "melody": {"type": "number", "minimum": 0, "maximum": 1},
    "cadence": {"type": "number", "minimum": 0, "maximum": 1},
    "refrain_or_formula": {"type": "number", "minimum": 0, "maximum": 1},
    "participation": {"type": "number", "minimum": 0, "maximum": 1},
    "embodiment": {"type": "number", "minimum": 0, "maximum": 1},
    "role_legitimacy": {"type": "number", "minimum": 0, "maximum": 1},
    "protocol_review": {"type": "number", "minimum": 0, "maximum": 1},
    "consent_status": {"type": "number", "minimum": 0, "maximum": 1},
    "access_control": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_oversight": {"type": "number", "minimum": 0, "maximum": 1},
    "benefit_sharing": {"type": "number", "minimum": 0, "maximum": 1},
    "quote_extraction_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "context_removal": {"type": "number", "minimum": 0, "maximum": 1},
    "sound_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "translation_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "extraction_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_control": {"type": "number", "minimum": 0, "maximum": 1},
    "community_sensitivity": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
