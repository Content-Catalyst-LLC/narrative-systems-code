{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interactive Narrative Governance Canvas Input",
  "type": "object",
  "required": [
    "item",
    "game_context",
    "choice_meaningfulness",
    "system_response",
    "feedback_clarity",
    "public_consequence"
  ],
  "properties": {
    "item": {"type": "string"},
    "game_context": {"type": "string"},
    "choice_meaningfulness": {"type": "number", "minimum": 0, "maximum": 1},
    "system_response": {"type": "number", "minimum": 0, "maximum": 1},
    "feedback_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "role_variation": {"type": "number", "minimum": 0, "maximum": 1},
    "world_memory": {"type": "number", "minimum": 0, "maximum": 1},
    "ethical_governance": {"type": "number", "minimum": 0, "maximum": 1},
    "branch_count_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "state_dependency": {"type": "number", "minimum": 0, "maximum": 1},
    "consequence_tracking": {"type": "number", "minimum": 0, "maximum": 1},
    "testing_load": {"type": "number", "minimum": 0, "maximum": 1},
    "localization_cost": {"type": "number", "minimum": 0, "maximum": 1},
    "recombination_coherence": {"type": "number", "minimum": 0, "maximum": 1},
    "mechanic_theme_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "rule_fiction_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "goal_value_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "progression_coherence": {"type": "number", "minimum": 0, "maximum": 1},
    "interface_legibility": {"type": "number", "minimum": 0, "maximum": 1},
    "consequence_consistency": {"type": "number", "minimum": 0, "maximum": 1},
    "failure_meaning": {"type": "number", "minimum": 0, "maximum": 1},
    "replay_value": {"type": "number", "minimum": 0, "maximum": 1},
    "player_consent": {"type": "number", "minimum": 0, "maximum": 1},
    "identity_care": {"type": "number", "minimum": 0, "maximum": 1},
    "generic_quest_generation": {"type": "number", "minimum": 0, "maximum": 1},
    "character_memory_failure": {"type": "number", "minimum": 0, "maximum": 1},
    "opaque_system_response": {"type": "number", "minimum": 0, "maximum": 1},
    "player_manipulation": {"type": "number", "minimum": 0, "maximum": 1},
    "harmful_stereotype_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
