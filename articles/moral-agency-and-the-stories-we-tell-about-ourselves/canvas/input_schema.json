{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Moral Agency Canvas Input",
  "type": "object",
  "required": [
    "item",
    "claim_context",
    "action_naming",
    "intention_distinction",
    "consequence_clarity",
    "harm_marking",
    "method_limits"
  ],
  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"},
    "action_naming": {"type": "number", "minimum": 0, "maximum": 1},
    "intention_distinction": {"type": "number", "minimum": 0, "maximum": 1},
    "consequence_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "harm_marking": {"type": "number", "minimum": 0, "maximum": 1},
    "repair_orientation": {"type": "number", "minimum": 0, "maximum": 1},
    "other_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "context_overuse": {"type": "number", "minimum": 0, "maximum": 1},
    "intention_shielding": {"type": "number", "minimum": 0, "maximum": 1},
    "victimhood_shielding": {"type": "number", "minimum": 0, "maximum": 1},
    "blame_shifting": {"type": "number", "minimum": 0, "maximum": 1},
    "growth_substitution": {"type": "number", "minimum": 0, "maximum": 1},
    "harm_minimization": {"type": "number", "minimum": 0, "maximum": 1},
    "harm_acknowledgment": {"type": "number", "minimum": 0, "maximum": 1},
    "apology_precision": {"type": "number", "minimum": 0, "maximum": 1},
    "material_response": {"type": "number", "minimum": 0, "maximum": 1},
    "conduct_change": {"type": "number", "minimum": 0, "maximum": 1},
    "future_accountability": {"type": "number", "minimum": 0, "maximum": 1},
    "third_party_oversight": {"type": "number", "minimum": 0, "maximum": 1},
    "source_context": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_notes": {"type": "number", "minimum": 0, "maximum": 1},
    "cultural_context": {"type": "number", "minimum": 0, "maximum": 1},
    "method_limits": {"type": "number", "minimum": 0, "maximum": 1},
    "review_owner_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
