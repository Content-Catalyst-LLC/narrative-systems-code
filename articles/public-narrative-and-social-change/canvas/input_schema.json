{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Public Narrative Governance Canvas Input",
  "type": "object",
  "required": [
    "item",
    "claim_context",
    "self_clarity",
    "us_clarity",
    "now_clarity",
    "public_consequence"
  ],
  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "self_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "us_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "now_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "value_articulation": {"type": "number", "minimum": 0, "maximum": 1},
    "action_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_review": {"type": "number", "minimum": 0, "maximum": 1},
    "diagnostic_frame": {"type": "number", "minimum": 0, "maximum": 1},
    "proposed_solution": {"type": "number", "minimum": 0, "maximum": 1},
    "resource_support": {"type": "number", "minimum": 0, "maximum": 1},
    "coalition_openness": {"type": "number", "minimum": 0, "maximum": 1},
    "tactical_action": {"type": "number", "minimum": 0, "maximum": 1},
    "feedback_loop": {"type": "number", "minimum": 0, "maximum": 1},
    "consent_deficit": {"type": "number", "minimum": 0, "maximum": 1},
    "emotional_targeting": {"type": "number", "minimum": 0, "maximum": 1},
    "safety_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "reuse_uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
    "visibility_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "agency": {"type": "number", "minimum": 0, "maximum": 1},
    "voice_plurality": {"type": "number", "minimum": 0, "maximum": 1},
    "affected_community_authority": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "digital_context": {"type": "number", "minimum": 0, "maximum": 1},
    "summary_dependence": {"type": "number", "minimum": 0, "maximum": 1},
    "omitted_voices": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "bias_reproduction": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_erasure": {"type": "number", "minimum": 0, "maximum": 1},
    "human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
