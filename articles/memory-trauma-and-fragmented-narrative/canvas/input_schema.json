  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"},
    "temporal_rupture": {"type": "number", "minimum": 0, "maximum": 1},
    "gap_marking": {"type": "number", "minimum": 0, "maximum": 1},
    "repetition_patterning": {"type": "number", "minimum": 0, "maximum": 1},
    "silence_respect": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_notes": {"type": "number", "minimum": 0, "maximum": 1},
    "contextual_care": {"type": "number", "minimum": 0, "maximum": 1},
    "consent": {"type": "number", "minimum": 0, "maximum": 1},
    "agency": {"type": "number", "minimum": 0, "maximum": 1},
    "privacy": {"type": "number", "minimum": 0, "maximum": 1},
    "relational_context": {"type": "number", "minimum": 0, "maximum": 1},
