    "state_transition_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "agent_goal_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "world_rule_consistency": {"type": "number", "minimum": 0, "maximum": 1},
    "temporal_mapping": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_quality": {"type": "number", "minimum": 0, "maximum": 1},
    "beat_template_dependence": {"type": "number", "minimum": 0, "maximum": 1},
    "universal_model_claims": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "genre_flattening": {"type": "number", "minimum": 0, "maximum": 1},
    "model_overconfidence": {"type": "number", "minimum": 0, "maximum": 1},
    "judgment_review": {"type": "number", "minimum": 0, "maximum": 1},
    "individual_agency_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "systemic_agency_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "network_mapping": {"type": "number", "minimum": 0, "maximum": 1},
