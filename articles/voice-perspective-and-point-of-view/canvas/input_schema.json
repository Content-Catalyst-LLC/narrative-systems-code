{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voice Perspective Canvas Input",
  "type": "object",
  "required": ["item", "story_type", "tone_stability", "diction_coherence", "knowledge_limits", "focalization_clarity"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "tone_stability": {"type": "number", "minimum": 0, "maximum": 1},
    "diction_coherence": {"type": "number", "minimum": 0, "maximum": 1},
    "rhetorical_habit": {"type": "number", "minimum": 0, "maximum": 1},
    "address_stability": {"type": "number", "minimum": 0, "maximum": 1},
    "judgment_coherence": {"type": "number", "minimum": 0, "maximum": 1},
    "knowledge_limits": {"type": "number", "minimum": 0, "maximum": 1},
    "interior_access": {"type": "number", "minimum": 0, "maximum": 1},
    "focalization_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "level_stability": {"type": "number", "minimum": 0, "maximum": 1},
    "source_boundaries": {"type": "number", "minimum": 0, "maximum": 1},
    "factual_unreliability": {"type": "number", "minimum": 0, "maximum": 1},
    "interpretive_unreliability": {"type": "number", "minimum": 0, "maximum": 1},
    "ethical_unreliability": {"type": "number", "minimum": 0, "maximum": 1},
    "memory_distortion": {"type": "number", "minimum": 0, "maximum": 1},
    "agency_gap": {"type": "number", "minimum": 0, "maximum": 1},
    "exposure_sensitivity": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "representation_gap": {"type": "number", "minimum": 0, "maximum": 1},
    "institutional_evasion": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
