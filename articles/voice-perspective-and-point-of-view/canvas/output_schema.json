{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Voice Perspective Canvas Output",
  "type": "object",
  "required": ["item", "voice_consistency", "perspective_access", "reliability_risk", "governance_priority_score", "review_priority"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "voice_consistency": {"type": "number"},
    "perspective_access": {"type": "number"},
    "reliability_risk": {"type": "number"},
    "governance_priority_score": {"type": "number"},
    "review_priority": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
