{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cultural Story Canvas Output",
  "type": "object",
  "required": ["item", "cultural_value_score", "transmission_score", "narrative_risk", "review_priority"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "cultural_value_score": {"type": "number"},
    "transmission_score": {"type": "number"},
    "narrative_risk": {"type": "number"},
    "review_priority_score": {"type": "number"},
    "review_priority": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
