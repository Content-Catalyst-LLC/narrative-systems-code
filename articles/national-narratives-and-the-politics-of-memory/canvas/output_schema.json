{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "National Memory Governance Canvas Output",
  "type": "object",
  "required": [
    "item",
    "claim_context",
    "memory_plurality",
    "national_myth_risk",
    "memory_accountability",
    "public_memory_infrastructure",
    "ai_memory_risk",
    "review_priority"
  ],
  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "memory_plurality": {"type": "number"},
    "national_myth_risk": {"type": "number"},
    "memory_accountability": {"type": "number"},
    "public_memory_infrastructure": {"type": "number"},
    "ai_memory_risk": {"type": "number"},
    "governance_priority_score": {"type": "number"},
    "review_priority": {"type": "string"}
  }
}
