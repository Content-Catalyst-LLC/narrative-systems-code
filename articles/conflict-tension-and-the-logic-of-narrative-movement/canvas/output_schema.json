{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Conflict Tension Canvas Output",
  "type": "object",
  "required": ["item", "conflict_clarity", "tension_durability", "narrative_movement", "conflict_risk", "governance_priority_score", "review_priority"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "conflict_clarity": {"type": "number"},
    "tension_durability": {"type": "number"},
    "narrative_movement": {"type": "number"},
    "conflict_risk": {"type": "number"},
    "governance_priority_score": {"type": "number"},
    "review_priority": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
