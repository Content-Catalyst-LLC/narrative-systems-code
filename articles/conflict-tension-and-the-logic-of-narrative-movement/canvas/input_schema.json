    "agency_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "stakes_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "relation_legibility": {"type": "number", "minimum": 0, "maximum": 1},
    "unresolved_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "meaningful_delay": {"type": "number", "minimum": 0, "maximum": 1},
