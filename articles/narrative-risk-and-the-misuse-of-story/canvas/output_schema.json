{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narrative Risk Governance Canvas Output",
  "type": "object",
  "required": [
    "item",
    "narrative_context",
    "narrative_risk",
    "evidence_integrity",
    "trust_repair_priority",
    "platform_amplification_risk",
    "ai_narrative_risk",
    "review_priority"
  ],
  "properties": {
    "item": {"type": "string"},
    "narrative_context": {"type": "string"},
    "narrative_risk": {"type": "number"},
    "evidence_integrity": {"type": "number"},
    "trust_repair_priority": {"type": "number"},
    "platform_amplification_risk": {"type": "number"},
    "ai_narrative_risk": {"type": "number"},
    "governance_priority_score": {"type": "number"},
    "review_priority": {"type": "string"}
  }
}
