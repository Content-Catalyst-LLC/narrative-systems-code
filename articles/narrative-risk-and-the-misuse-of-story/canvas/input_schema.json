{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Narrative Risk Governance Canvas Input",
  "type": "object",
  "required": [
    "item",
    "narrative_context",
    "scapegoating",
    "evidence_immunity",
    "revision_openness",
    "public_consequence"
  ],
  "properties": {
    "item": {"type": "string"},
    "narrative_context": {"type": "string"},
    "scapegoating": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_immunity": {"type": "number", "minimum": 0, "maximum": 1},
    "mythic_simplification": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "group_blame_intensity": {"type": "number", "minimum": 0, "maximum": 1},
    "revision_openness": {"type": "number", "minimum": 0, "maximum": 1},
    "corroboration": {"type": "number", "minimum": 0, "maximum": 1},
    "source_quality": {"type": "number", "minimum": 0, "maximum": 1},
    "timeline_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_disclosure": {"type": "number", "minimum": 0, "maximum": 1},
    "accountability_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "disconfirmation_openness": {"type": "number", "minimum": 0, "maximum": 1},
    "institutional_failure": {"type": "number", "minimum": 0, "maximum": 1},
    "opacity": {"type": "number", "minimum": 0, "maximum": 1},
    "historical_distrust_reason": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "correction_difficulty": {"type": "number", "minimum": 0, "maximum": 1},
    "affected_listener_stakes": {"type": "number", "minimum": 0, "maximum": 1},
    "platform_speed": {"type": "number", "minimum": 0, "maximum": 1},
    "repetition_intensity": {"type": "number", "minimum": 0, "maximum": 1},
    "social_proof_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "monetization_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "synthetic_evidence": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance_opacity": {"type": "number", "minimum": 0, "maximum": 1},
    "fabricated_patterning": {"type": "number", "minimum": 0, "maximum": 1},
    "automated_consensus": {"type": "number", "minimum": 0, "maximum": 1},
    "vulnerability_targeting": {"type": "number", "minimum": 0, "maximum": 1},
    "human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
