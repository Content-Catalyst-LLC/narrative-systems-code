{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heroine Journey Canvas Output",
  "type": "object",
  "required": [
    "item",
    "claim_context",
    "heroine_alignment",
    "framework_risk",
    "critique_readiness",
    "integration_quality",
    "review_priority"
  ],
  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "heroine_alignment": {"type": "number"},
    "framework_risk": {"type": "number"},
    "critique_readiness": {"type": "number"},
    "integration_quality": {"type": "number"},
    "governance_priority_score": {"type": "number"},
    "review_priority": {"type": "string"}
  }
}
