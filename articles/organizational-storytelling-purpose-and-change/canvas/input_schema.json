{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Organizational Story Governance Canvas Input",
  "type": "object",
  "required": [
    "item",
    "claim_context",
    "mission_clarity",
    "decision_alignment",
    "employee_experience",
    "public_consequence"
  ],
  "properties": {
    "item": {"type": "string"},
    "claim_context": {"type": "string"},
    "mission_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "decision_alignment": {"type": "number", "minimum": 0, "maximum": 1},
    "budget_fit": {"type": "number", "minimum": 0, "maximum": 1},
    "stakeholder_impact": {"type": "number", "minimum": 0, "maximum": 1},
    "employee_experience": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_transparency": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "participation_integrity": {"type": "number", "minimum": 0, "maximum": 1},
    "resource_support": {"type": "number", "minimum": 0, "maximum": 1},
    "loss_acknowledgment": {"type": "number", "minimum": 0, "maximum": 1},
    "feedback_loops": {"type": "number", "minimum": 0, "maximum": 1},
    "accountability_measures": {"type": "number", "minimum": 0, "maximum": 1},
    "consent_deficit": {"type": "number", "minimum": 0, "maximum": 1},
    "selection_bias": {"type": "number", "minimum": 0, "maximum": 1},
    "power_asymmetry": {"type": "number", "minimum": 0, "maximum": 1},
    "emotional_targeting": {"type": "number", "minimum": 0, "maximum": 1},
    "brand_repurposing": {"type": "number", "minimum": 0, "maximum": 1},
    "agency": {"type": "number", "minimum": 0, "maximum": 1},
    "employee_voice_protection": {"type": "number", "minimum": 0, "maximum": 1},
    "dissent_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "memory_preservation": {"type": "number", "minimum": 0, "maximum": 1},
    "learning_followthrough": {"type": "number", "minimum": 0, "maximum": 1},
    "summary_dependence": {"type": "number", "minimum": 0, "maximum": 1},
    "omitted_dissent": {"type": "number", "minimum": 0, "maximum": 1},
    "context_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "privacy_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_erasure": {"type": "number", "minimum": 0, "maximum": 1},
    "human_review": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
