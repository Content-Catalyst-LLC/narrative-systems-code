{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Oral Storytelling Variation Canvas Input",
  "type": "object",
  "required": ["item", "storytelling_context", "teller_role", "audience_documentation", "variation_tracking"],
  "properties": {
    "item": {"type": "string"},
    "storytelling_context": {"type": "string"},
    "teller_role": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_documentation": {"type": "number", "minimum": 0, "maximum": 1},
    "occasion_context": {"type": "number", "minimum": 0, "maximum": 1},
    "place_linkage": {"type": "number", "minimum": 0, "maximum": 1},
    "embodiment": {"type": "number", "minimum": 0, "maximum": 1},
    "interaction_notes": {"type": "number", "minimum": 0, "maximum": 1},
    "repetition": {"type": "number", "minimum": 0, "maximum": 1},
    "formula_use": {"type": "number", "minimum": 0, "maximum": 1},
    "sequence_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_recognition": {"type": "number", "minimum": 0, "maximum": 1},
    "community_correction": {"type": "number", "minimum": 0, "maximum": 1},
    "transmission_pathway": {"type": "number", "minimum": 0, "maximum": 1},
    "variation_tracking": {"type": "number", "minimum": 0, "maximum": 1},
    "context_explanation": {"type": "number", "minimum": 0, "maximum": 1},
    "language_notes": {"type": "number", "minimum": 0, "maximum": 1},
    "source_review": {"type": "number", "minimum": 0, "maximum": 1},
    "access_protocol": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_oversight": {"type": "number", "minimum": 0, "maximum": 1},
    "fixation_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "context_removal": {"type": "number", "minimum": 0, "maximum": 1},
    "performance_omission": {"type": "number", "minimum": 0, "maximum": 1},
    "translation_loss": {"type": "number", "minimum": 0, "maximum": 1},
    "extraction_risk": {"type": "number", "minimum": 0, "maximum": 1},
    "governance_control": {"type": "number", "minimum": 0, "maximum": 1},
    "community_sensitivity": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
