{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plot Coherence Canvas Input",
  "type": "object",
  "required": ["item", "story_type", "action_clarity", "causal_linkage", "motivation_visibility", "episode_dependency"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "action_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "causal_linkage": {"type": "number", "minimum": 0, "maximum": 1},
    "motivation_visibility": {"type": "number", "minimum": 0, "maximum": 1},
    "episode_dependency": {"type": "number", "minimum": 0, "maximum": 1},
    "turning_point_strength": {"type": "number", "minimum": 0, "maximum": 1},
    "resolution_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "state_change": {"type": "number", "minimum": 0, "maximum": 1},
    "knowledge_change": {"type": "number", "minimum": 0, "maximum": 1},
    "pressure_change": {"type": "number", "minimum": 0, "maximum": 1},
    "relationship_impact": {"type": "number", "minimum": 0, "maximum": 1},
    "future_movement": {"type": "number", "minimum": 0, "maximum": 1},
    "false_causality": {"type": "number", "minimum": 0, "maximum": 1},
    "simplification_bias": {"type": "number", "minimum": 0, "maximum": 1},
    "closure_pressure": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_omission": {"type": "number", "minimum": 0, "maximum": 1},
    "uncertainty_clarity": {"type": "number", "minimum": 0, "maximum": 1},
    "audience_sensitivity": {"type": "number", "minimum": 0, "maximum": 1},
    "public_consequence": {"type": "number", "minimum": 0, "maximum": 1},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
