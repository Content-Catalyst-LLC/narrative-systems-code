{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Story Media History Canvas Output",
  "type": "object",
  "required": ["medium", "transmission_strength", "participation_score", "preservation_risk", "review_priority"],
  "properties": {
    "medium": {"type": "string"},
    "period_label": {"type": "string"},
    "transmission_strength": {"type": "number"},
    "participation_score": {"type": "number"},
    "preservation_risk": {"type": "number"},
    "review_priority": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
