{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Beginning Closure Canvas Output",
  "type": "object",
  "required": ["item", "opening_clarity", "closure_integrity", "beginning_ending_alignment", "closure_risk", "governance_priority_score", "review_priority"],
  "properties": {
    "item": {"type": "string"},
    "story_type": {"type": "string"},
    "opening_clarity": {"type": "number"},
    "closure_integrity": {"type": "number"},
    "beginning_ending_alignment": {"type": "number"},
    "closure_risk": {"type": "number"},
    "governance_priority_score": {"type": "number"},
    "review_priority": {"type": "string"},
    "owner": {"type": "string"},
    "status": {"type": "string"}
  }
}
